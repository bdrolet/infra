# Grafana Cloud Prometheus remote_write credentials.
# Find these at: grafana.com → your stack → Details → Prometheus → Remote Write
# Copy to secret.yaml, fill in values, and apply:
#   kubectl apply -f observability/alloy/secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: grafana-cloud-prometheus
  namespace: observability
stringData:
  url: "https://prometheus-prod-XX-prod-us-west-0.grafana.net/api/prom/push"
  username: "<grafana-cloud-metrics-instance-id>"
  password: "<grafana-cloud-api-key>"
