apiVersion: v1
kind: Secret
metadata:
  name: openclaw-credentials
  namespace: apps
type: Opaque
stringData:
  # Generate with: openssl rand -hex 32
  GOG_KEYRING_PASSWORD: REPLACE_ME
  # Leave blank to auto-generate on first start, or set explicitly
  OPENCLAW_GATEWAY_TOKEN: ""
  # Claude.ai session key — uses your existing Claude subscription (no extra API cost)
  # Get from: claude.ai → DevTools → Application → Cookies → sessionKey
  CLAUDE_AI_SESSION_KEY: REPLACE_ME
