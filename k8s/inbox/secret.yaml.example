# Copy to secret.yaml (gitignored) and fill in real values, then:
#   kubectl apply -f k8s/inbox/secret.yaml
#
# Azure app registration credentials for the inbox worker.
# The MSAL token cache stays in GCP Secret Manager (read at runtime via Workload Identity).
apiVersion: v1
kind: Secret
metadata:
  name: inbox-azure-credentials
  namespace: apps
type: Opaque
stringData:
  CLIENT_ID: REPLACE_ME
  CLIENT_SECRET: REPLACE_ME
  TENANT_ID: REPLACE_ME
  OPENAI_API_KEY: REPLACE_ME   # remove in Phase 5
