# Grafana Cloud OTLP credentials — same account used by the inbox worker.
# Find these at: grafana.com → your stack → Details → OpenTelemetry
# Copy to secret.yaml, fill in values, and apply:
#   kubectl apply -f k8s/billing-exporter/secret.yaml
apiVersion: v1
kind: Secret
metadata:
  name: grafana-cloud-otlp
  namespace: apps
stringData:
  GRAFANA_OTLP_ENDPOINT: "https://otlp-gateway-prod-us-west-0.grafana.net/otlp"
  GRAFANA_OTLP_TOKEN: "<base64(instanceId:apiKey)>"
